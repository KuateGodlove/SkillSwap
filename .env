# --- SERVER CONFIG ---
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/skillswapp
JWT_SECRET=your_super_secret_jwt_key_here
FRONTEND_URL=http://localhost:5173

# --- EMAIL CONFIGURATION (Choose One Option Below) ---

# OPTION 1: Mailtrap (Best for Development/Testing)
# Get these credentials from https://mailtrap.io > Inboxes > SMTP Settings
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_EMAIL=your_mailtrap_username
SMTP_PASSWORD=your_mailtrap_password
FROM_EMAIL=noreply@skillswapp.com
FROM_NAME=SkillSwapp

# OPTION 2: Gmail (Good for quick Production-like tests)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_EMAIL=your.email@gmail.com
# SMTP_PASSWORD=your_16_char_app_password
# FROM_EMAIL=your.email@gmail.com
# FROM_NAME=SkillSwapp